{
  "manifest_version": 3,
  "name": "Webnotes",
  "version": "1.0.0",
  "description": "Add draggable sticky notes to any web page",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
